<script>
function toggleMobileMenuSheet(force) {
  var sheet = document.getElementById('menuSheet');
  var overlay = document.getElementById('menuSheetOverlay');
  var floaters = document.querySelector('.floaters');
  if (!sheet || !overlay) return;
  var isOpen = force !== undefined ? force : !sheet.classList.contains('open');
  if (isOpen) {
    sheet.classList.add('open');
    overlay.classList.add('open');
    if (floaters) floaters.style.display = 'none';
    document.body.style.overflow = 'hidden';
  } else {
    sheet.classList.remove('open');
    overlay.classList.remove('open');
    if (floaters && !document.body.classList.contains('has-prop-cta')) floaters.style.display = '';
    document.body.style.overflow = '';
  }
}
</script>
