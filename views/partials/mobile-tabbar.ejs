<%
  var _p = (typeof path !== 'undefined' && path) ? path : '/';
  function on(test){ return test ? ' is-active' : ''; }
  var isHome   = _p === '/';
  var isBuy    = _p.indexOf('/properties') === 0 || _p.indexOf('/property') === 0;
  var isLoans  = _p.indexOf('/loans') === 0;
  var isServ   = _p.indexOf('/services') === 0;
  var isEnq    = _p.indexOf('/contact') === 0;
%>
<nav class="tabbar" aria-label="Quick navigation">
  <a href="/" class="tab<%= on(isHome) %>" aria-label="Home">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 12 4l9 7M5 9.5V20h5v-6h4v6h5V9.5"/></svg>
    <span>Home</span>
  </a>
  <a href="/properties?listing=sale" class="tab<%= on(isBuy) %>" aria-label="Browse properties">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
    <span>Browse</span>
  </a>
  <a href="/contact" class="tab tab-cta" aria-label="Enquire now">
    <span class="cta-ring">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.4L3 21l1.1-3.9A8.4 8.4 0 1 1 21 11.5z"/></svg>
    </span>
    <span>Enquire</span>
  </a>
  <a href="/loans" class="tab<%= on(isLoans) %>" aria-label="Home loans">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="8" cy="6" rx="5" ry="2.4"/><path d="M3 6v4c0 1.3 2.2 2.4 5 2.4s5-1.1 5-2.4V6"/><path d="M11 13v3.5c0 1.3 2.2 2.4 5 2.4s5-1.1 5-2.4V13c0-1.3-2.2-2.4-5-2.4"/></svg>
    <span>Loans</span>
  </a>
  <a href="/services" class="tab<%= on(isServ) %>" aria-label="Services">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.4"/><rect x="14" y="3" width="7" height="7" rx="1.4"/><rect x="3" y="14" width="7" height="7" rx="1.4"/><rect x="14" y="14" width="7" height="7" rx="1.4"/></svg>
    <span>Services</span>
  </a>
</nav>
