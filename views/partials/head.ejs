<!-- WebSite + Sitelinks SearchBox -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "<%= _site %>/#website",
  "url": "<%= _site %>",
  "name": "RichManAssets — Real Estate in Udupi & Mangaluru",
  "description": "Buy, sell, rent or lease property in Udupi, Manipal, Mangaluru and coastal Karnataka.",
  "publisher": { "@id": "<%= _site %>/#organization" },
  "inLanguage": "en-IN",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "<%= _site %>/properties?area={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

