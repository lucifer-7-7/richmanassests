<%
  var _site = (typeof locals.siteUrl !== 'undefined' && locals.siteUrl) ? locals.siteUrl : 'https://richmanassets.com';
  var _canonical = (typeof locals.canonical !== 'undefined' && locals.canonical) ? locals.canonical : _site;
  var _desc = (typeof locals.description !== 'undefined' && locals.description)
    ? locals.description
    : 'Buy, rent or lease property in Udupi, Mangaluru & coastal Karnataka. Verified villas, 2BHK & 3BHK apartments, residential plots, commercial space, beach-facing land & agricultural sites. Home loans, legal services & interiors under one roof. 15+ years · 1,200+ families · ₹500 Cr+ transacted.';
  var _ogImg = (typeof locals.ogImage !== 'undefined' && locals.ogImage) ? locals.ogImage : (_site + '/assets/img/site-hero.jpg');
  if (_ogImg.indexOf('http') !== 0) _ogImg = _site + (_ogImg.charAt(0) === '/' ? '' : '/') + _ogImg;
  var _ogType = (typeof locals.ogType !== 'undefined' && locals.ogType) ? locals.ogType : 'website';
  var _robots = (typeof locals.robots !== 'undefined' && locals.robots) ? locals.robots : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
  var _pageTitle = (typeof locals.title !== 'undefined') ? locals.title : 'RichManAssets';
%>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<title><%= title %></title>
<meta name="description" content="<%= _desc %>"/>
<meta name="robots" content="<%= _robots %>"/>
<link rel="canonical" href="<%= _canonical %>"/>
<meta name="theme-color" content="#17150F"/>

<!-- Geo targeting (Google & Bing local signals) -->
<meta name="geo.region" content="IN-KA"/>
<meta name="geo.placename" content="Udupi, Karnataka, India"/>
<meta name="geo.position" content="13.343869;74.7435883"/>
<meta name="ICBM" content="13.343869, 74.7435883"/>

<!-- Language & region targeting -->
<link rel="alternate" hreflang="en-IN" href="<%= _canonical %>"/>
<link rel="alternate" hreflang="en" href="<%= _canonical %>"/>

<!-- Open Graph -->
<meta property="og:type" content="<%= _ogType %>"/>
<meta property="og:title" content="<%= title %>"/>
<meta property="og:description" content="<%= _desc %>"/>
<meta property="og:image" content="<%= _ogImg %>"/>
<meta property="og:image:width" content="1200"/>
<meta property="og:image:height" content="630"/>
<meta property="og:image:alt" content="<%= _pageTitle %> — Real Estate in Udupi & Mangaluru"/>
<meta property="og:url" content="<%= _canonical %>"/>
<meta property="og:site_name" content="RichManAssets"/>
<meta property="og:locale" content="en_IN"/>

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="<%= title %>"/>
<meta name="twitter:description" content="<%= _desc %>"/>
<meta name="twitter:image" content="<%= _ogImg %>"/>
<meta name="twitter:image:alt" content="<%= _pageTitle %> — Udupi Real Estate"/>

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400;1,6..72,500&family=Hanken+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- Smooth scroll library -->
<link rel="stylesheet" href="https://unpkg.com/lenis@1.1.13/dist/lenis.css">

<link rel="stylesheet" href="/assets/site.css?v=3">
<link rel="stylesheet" href="/assets/market.css?v=3">

