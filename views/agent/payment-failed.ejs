<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title><%= title %></title><meta name="robots" content="noindex,nofollow"/>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/agent.css">
</head>
<body class="agent-portal">
<div class="result-page">
  <div class="result-box">
    <div class="result-icon fail">
      <svg viewBox="0 0 24 24" fill="none" stroke="#E05353" stroke-width="2.5" width="36" height="36"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </div>
    <h1>Payment Failed</h1>
    <p>Your payment could not be completed. <strong>No amount has been charged.</strong> Your listing draft is safe — you can retry the payment anytime.</p>
    <a href="/agent/listings" class="btn btn-primary btn-full" style="margin-bottom:10px">Retry Payment →</a>
    <a href="/agent/dashboard" class="btn btn-ghost btn-full">Back to Dashboard</a>
    <p style="margin-top:20px;font-size:12px;color:var(--muted)">If you believe this is an error, please contact us at hello@richmanassets.com with your listing details.</p>
  </div>
</div>
</body>
</html>
