<%- include('../partials/agent-layout-start', { activeNav: 'listings', pageTitle: 'Pay to Publish' }) %>

<% if (flash) { %><div class="flash <%= flash.type %>"><%- flash.msg %></div><% } %>

<div class="payment-summary">
  <div style="text-align:center;margin-bottom:28px">
    <div style="font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Listing Fee</div>
    <div class="amount">₹<%= feeRs %></div>
    <div class="amount-label">One-time fee · 1 year listing</div>
  </div>

  <div class="payment-row">
    <span class="pkey">Property</span>
    <span class="pval" style="max-width:60%;text-align:right"><%= prop.name %></span>
  </div>
  <div class="payment-row">
    <span class="pkey">Location</span>
    <span class="pval"><%= prop.loc %></span>
  </div>
  <div class="payment-row">
    <span class="pkey">Type</span>
    <span class="pval"><%= prop.type %> · For <%= prop.listing %></span>
  </div>
  <div class="payment-row">
    <span class="pkey">Price</span>
    <span class="pval"><%= prop.price %></span>
  </div>
  <div class="payment-row">
    <span class="pkey">Listing valid for</span>
    <span class="pval">1 Year from payment</span>
  </div>
  <div class="payment-row" style="border-bottom:2px solid var(--gold);margin-bottom:20px">
    <span class="pkey" style="font-weight:700;color:var(--cream)">Total</span>
    <span class="pval" style="color:var(--gold);font-weight:700;font-size:18px">₹<%= feeRs %></span>
  </div>

  <div id="payError" class="flash err" style="display:none"></div>

  <button id="payBtn" class="btn btn-primary btn-full btn-lg" onclick="initPayment()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
    Pay ₹<%= feeRs %> Securely
  </button>

  <p style="text-align:center;font-size:12px;color:var(--muted);margin-top:16px">
    🔒 Payments secured by Cashfree · UPI, Cards, Net Banking accepted
  </p>
  <div style="text-align:center;margin-top:12px">
    <a href="/agent/listings" class="btn btn-ghost btn-sm">← Back to listings</a>
  </div>
</div>

<!-- Cashfree JS SDK -->
<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
<script>
var CASHFREE_ENV   = '<%= cashfreeEnv %>';
var PROPERTY_ID    = '<%- prop.id %>';

async function initPayment() {
  var btn = document.getElementById('payBtn');
  var errDiv = document.getElementById('payError');
  btn.disabled = true;
  btn.textContent = 'Initialising…';
  errDiv.style.display = 'none';

  try {
    // Create order on backend
    var resp = await fetch('/agent/payment/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ property_id: PROPERTY_ID }),
    });
    var data = await resp.json();

    if (!data.ok) {
      throw new Error(data.error || 'Could not create payment order.');
    }

    // Launch Cashfree checkout
    var cashfree = Cashfree({ mode: CASHFREE_ENV });
    cashfree.checkout({
      paymentSessionId: data.data.payment_session_id,
      returnUrl: window.location.origin + '/agent/payment/status/' + data.data.internal_order_id,
      redirectTarget: '_self',
    }).then(function(result) {
      if (result.error) {
        throw new Error(result.error.message || 'Payment failed.');
      }
      // success redirect handled by Cashfree returnUrl
    }).catch(function(err) {
      btn.disabled = false;
      btn.innerHTML = 'Pay ₹<%= feeRs %> Securely';
      errDiv.style.display = 'flex';
      errDiv.textContent = err.message || 'Payment could not be completed. Please try again.';
    });

  } catch (err) {
    btn.disabled = false;
    btn.innerHTML = 'Pay ₹<%= feeRs %> Securely';
    errDiv.style.display = 'flex';
    errDiv.textContent = err.message || 'Something went wrong. Please try again.';
  }
}
</script>

<%- include('../partials/agent-layout-end') %>
