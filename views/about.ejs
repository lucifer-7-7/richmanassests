<!doctype html>
<html lang="en">
<head>
<%- include('partials/head') %>
<link rel="stylesheet" href="/assets/market.css?v=3">
<style>
  .about-hero{
    background:var(--ink);color:var(--paper);
    padding:clamp(120px,16vw,180px) 0 clamp(56px,8vw,96px);
    position:relative;overflow:hidden;
  }
  .about-hero::before{
    content:"";position:absolute;right:-10%;top:-20%;
    width:60vw;max-width:700px;aspect-ratio:1;border-radius:50%;
    background:radial-gradient(circle,rgba(154,123,63,.12),transparent 70%);
    pointer-events:none;
  }
  .about-hero h1{
    font-family:var(--f-display);font-weight:400;
    font-size:clamp(36px,6vw,84px);line-height:.96;letter-spacing:-.024em;
    text-wrap:balance;max-width:16ch;
  }
  .about-hero h1 .it{font-style:italic;color:var(--accent-soft)}
  .about-hero p{
    margin-top:22px;max-width:52ch;
    font-size:clamp(15px,1.5vw,17px);line-height:1.68;
    color:rgba(247,244,237,.74);
  }
  .about-hero .hero-meta{
    display:flex;gap:clamp(20px,3vw,40px);flex-wrap:wrap;
    margin-top:36px;padding-top:32px;
    border-top:1px solid rgba(247,244,237,.12);
  }
  .about-hero .hero-meta div .v{
    font-family:var(--f-display);font-size:clamp(28px,3.4vw,44px);
    font-weight:500;letter-spacing:-.02em;color:var(--gold);
  }
  .about-hero .hero-meta div .l{
    font-family:var(--f-mono);font-size:10.5px;letter-spacing:.12em;
    text-transform:uppercase;color:rgba(247,244,237,.44);margin-top:5px;
  }

  /* prose sections */
  .about-sec{padding:clamp(64px,9vw,112px) 0}
  .about-grid{
    display:grid;gap:clamp(36px,6vw,80px);align-items:start;
  }
  @media(min-width:880px){.about-grid{grid-template-columns:1fr 1fr}}
  @media(min-width:880px){.about-grid.flip .prose{order:2}}
  @media(min-width:880px){.about-grid.flip .media-col{order:1}}
  .prose .label{
    font-family:var(--f-mono);font-size:11px;letter-spacing:.24em;
    text-transform:uppercase;color:var(--accent);margin-bottom:16px;display:block;
  }
  .prose h2{
    font-family:var(--f-display);font-weight:400;
    font-size:clamp(28px,3.8vw,50px);line-height:1.04;letter-spacing:-.018em;
    text-wrap:balance;margin-bottom:20px;
  }
  .prose h2 .it{font-style:italic;color:var(--accent)}
  .prose p{
    font-size:clamp(14.5px,1.4vw,16.5px);line-height:1.74;
    color:var(--ink-2);margin-bottom:18px;max-width:54ch;
  }
  .prose p:last-child{margin-bottom:0}
  .prose ul{list-style:none;margin-top:20px;display:flex;flex-direction:column;gap:10px}
  .prose ul li{
    display:flex;gap:12px;align-items:baseline;
    font-size:14.5px;color:var(--ink-2);
    padding:10px 0;border-bottom:1px solid var(--line-soft);
  }
  .prose ul li .d{
    width:5px;height:5px;border-radius:50%;
    background:var(--gold-deep);flex:none;transform:translateY(-2px);
  }

  .media-col{border-radius:16px;overflow:hidden;background:var(--paper-2)}
  .media-col img{width:100%;height:100%;object-fit:cover;display:block}
  .media-col.dark{
    background:var(--ink);border-radius:16px;
    padding:clamp(28px,3.6vw,48px);color:var(--paper);
    display:flex;flex-direction:column;gap:clamp(20px,2.8vw,32px);
  }
  .media-col.dark h3{
    font-family:var(--f-display);font-weight:400;
    font-size:clamp(22px,2.6vw,34px);letter-spacing:-.015em;
    color:var(--paper);line-height:1.08;
  }
  .media-col.dark h3 .it{font-style:italic;color:var(--gold)}
  .media-col.dark p{font-size:14.5px;line-height:1.66;color:rgba(247,244,237,.7)}

  /* location grid */
  .loc-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
    gap:clamp(10px,1.4vw,18px);margin-top:clamp(32px,4vw,52px);
  }
  .loc-card{
    background:var(--paper);border:1px solid var(--line);
    border-radius:12px;padding:clamp(16px,2vw,24px);
    transition:.36s ease;
  }
  .loc-card:hover{border-color:var(--accent);transform:translateY(-3px)}
  .loc-card h4{
    font-family:var(--f-display);font-weight:500;
    font-size:clamp(18px,1.9vw,24px);margin-bottom:7px;letter-spacing:-.01em;
  }
  .loc-card p{font-size:13px;color:var(--ink-3);line-height:1.5}
  .loc-card .pill-row{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
  .loc-card .pill{
    font-family:var(--f-mono);font-size:9.5px;letter-spacing:.08em;
    text-transform:uppercase;color:var(--ink-3);border:1px solid var(--line);
    border-radius:100px;padding:5px 10px;
  }

  /* trust */
  .trust-block{
    background:var(--paper-2);border-radius:16px;
    padding:clamp(28px,3.6vw,48px);
    display:grid;gap:clamp(16px,2vw,24px);
    grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
  }
  .trust-block .t{
    display:flex;flex-direction:column;gap:6px;
    padding:clamp(14px,1.8vw,22px);background:var(--paper);
    border-radius:10px;border:1px solid var(--line-soft);
  }
  .trust-block .t .v{
    font-family:var(--f-display);font-size:clamp(26px,3vw,36px);
    font-weight:500;letter-spacing:-.02em;color:var(--accent);
  }
  .trust-block .t .l{
    font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;
    text-transform:uppercase;color:var(--muted);
  }

  /* team values */
  .values-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:clamp(12px,1.6vw,20px);margin-top:clamp(32px,4vw,52px);
  }
  .value-card{
    padding:clamp(20px,2.4vw,30px);border:1px solid var(--line);
    border-radius:12px;transition:.36s ease;
    background:var(--paper);
  }
  .value-card:hover{border-color:var(--ink);background:var(--ink);color:var(--paper)}
  .value-card:hover p{color:rgba(247,244,237,.7)}
  .value-card .n{
    font-family:var(--f-mono);font-size:11px;letter-spacing:.14em;
    text-transform:uppercase;color:var(--muted);margin-bottom:14px;display:block;
    transition:.36s ease;
  }
  .value-card:hover .n{color:rgba(247,244,237,.5)}
  .value-card h4{
    font-family:var(--f-display);font-size:clamp(18px,1.8vw,22px);
    font-weight:500;margin-bottom:9px;letter-spacing:-.01em;
  }
  .value-card p{font-size:13.5px;color:var(--ink-3);line-height:1.58;transition:.36s ease}

  /* google rating widget */
  .rating-band{
    background:var(--ink);color:var(--paper);
    padding:clamp(40px,6vw,72px) 0;
    text-align:center;
  }
  .rating-band .r-score{
    font-family:var(--f-display);font-size:clamp(56px,10vw,100px);
    font-weight:400;letter-spacing:-.04em;line-height:1;color:var(--gold);
  }
  .rating-band .r-stars{display:flex;justify-content:center;gap:6px;margin:10px 0}
  .rating-band .r-stars svg{width:22px;height:22px;fill:var(--gold)}
  .rating-band .r-label{
    font-family:var(--f-mono);font-size:11px;letter-spacing:.18em;
    text-transform:uppercase;color:rgba(247,244,237,.44);
  }
  .rating-band .r-note{
    margin-top:6px;font-size:14px;color:rgba(247,244,237,.62);max-width:34ch;margin-inline:auto;
  }
  .crumb{display:flex;align-items:center;gap:8px;font-family:var(--f-mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:20px}
  .crumb a{color:var(--muted);text-decoration:none;transition:.2s}.crumb a:hover{color:var(--ink)}
  .crumb .sep{color:var(--line)}
  /* FAQ */
  .faq-list{display:flex;flex-direction:column;gap:0;margin-top:8px}
  .faq-item{border-bottom:1px solid var(--line-soft)}
  .faq-item summary{
    list-style:none;cursor:pointer;padding:20px 36px 20px 0;position:relative;
    font-family:var(--f-display);font-size:clamp(17px,2.2vw,21px);font-weight:400;
    color:var(--ink);transition:color .2s;
  }
  .faq-item summary::-webkit-details-marker{display:none}
  .faq-item summary::after{
    content:"+";position:absolute;right:4px;top:50%;transform:translateY(-50%);
    font-size:24px;color:var(--accent);transition:transform .3s;line-height:1;
  }
  .faq-item[open] summary::after{content:"–"}
  .faq-item summary:hover{color:var(--accent)}
  .faq-item p{padding:0 0 22px;color:var(--ink-3);font-size:15px;line-height:1.65;max-width:64ch}
</style>

