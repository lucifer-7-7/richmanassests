</section>

<!-- DESIGN PROCESS SECTION -->
<section class="interiors-process-sec">
  <div class="wrap">
    <div class="sec-head">
      <span class="kicker">How We Work</span>
      <h2>Our 3-Step Turnkey Interior Workflow</h2>
    </div>

    <div class="process-grid">
      <div class="process-card">
        <div class="step-num">01 · CONCEPT &amp; 3D RENDERS</div>
        <h3>3D Visualisation &amp; Space Planning</h3>
        <p>We produce photorealistic 3D renders, material mood boards, and detailed floor plans before a single wall is touched.</p>
      </div>

      <div class="process-card">
        <div class="step-num">02 · MATERIAL SELECTION</div>
        <h3>Curated Woods, Stones &amp; Metals</h3>
        <p>You inspect actual wood samples, marble slabs, hardware, and fabrics in person with our senior interior architects.</p>
      </div>

      <div class="process-card">
        <div class="step-num">03 · TURNKEY EXECUTION</div>
        <h3>In-House Joinery &amp; On-Time Delivery</h3>
        <p>Our experienced craftsmen handle all civil, electrical, carpentry, and final styling with fixed timeline guarantees.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="interiors-cta-sec wrap">
  <div class="interiors-cta-box">
    <h2>Ready to transform your home or office?</h2>
    <p>Schedule a free consultation and 3D space assessment with RichManAssets' interior design team.</p>
    <a href="/contact?service=interior" class="btn-gold">Book Free Interior Consultation →</a>
  </div>
</section>

<%- include('partials/footer') %>
<%- include('partials/mobile-tabbar') %>

<script>
function filterInteriors(cat, btn) {
  var pills = document.querySelectorAll('#intPills .int-pill');
  pills.forEach(function(p) { p.classList.remove('active'); });
  if (btn) btn.classList.add('active');

  var cards = document.querySelectorAll('#intGrid .int-card');
  cards.forEach(function(card) {
    if (cat === 'all' || card.getAttribute('data-category') === cat) {
      card.style.display = 'flex';
    } else {
      card.style.display = 'none';
    }
  });
}
</script>

</body>
</html>
