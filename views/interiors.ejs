<!doctype html>
<html lang="en">
<head>
<%- include('partials/head') %>
<link rel="stylesheet" href="/assets/market.css?v=3">
<link rel="stylesheet" href="/assets/interiors.css?v=1">
</head>
<body data-screen-label="Interior Design">

<%- include('partials/nav') %>

<!-- HERO HEADER -->
<header class="interiors-hero wrap">
  <div class="crumb" style="justify-content:center;margin-bottom:12px;">
    <a href="/">Home</a><span class="sep">/</span><a href="/services">Services</a><span class="sep">/</span><span>Interior Design</span>
  </div>
  <span class="kicker">Bespoke Spaces &amp; Turnkey Interiors</span>
  <h1>Creative Interiors Designed for <span class="it">Coastal Living.</span></h1>
  <p class="lead">From beachfront luxury villas to modern corporate offices in Udupi &amp; Mangaluru, we craft signature interiors with 3D visualization, custom joinery, and turnkey execution.</p>

  <div class="interiors-stats-row">
    <div class="item"><span>45+ Projects Delivered</span></div>
    <div class="dot"></div>
    <div class="item"><span>3D Render Visualization</span></div>
    <div class="dot"></div>
    <div class="item"><span>Turnkey Execution</span></div>
  </div>
</header>

<!-- CATEGORY FILTER BAR -->
<div class="interiors-filter-bar wrap">
  <div class="filter-pills" id="intPills">
    <button class="int-pill active" onclick="filterInteriors('all', this)">All Works</button>
    <button class="int-pill" onclick="filterInteriors('villas', this)">Coastal Villas</button>
    <button class="int-pill" onclick="filterInteriors('kitchens', this)">Modular Kitchens</button>
    <button class="int-pill" onclick="filterInteriors('lounges', this)">Penthouse &amp; Lounges</button>
    <button class="int-pill" onclick="filterInteriors('offices', this)">Executive Offices</button>
  </div>
</div>

<!-- PORTFOLIO GRID -->
<section class="interiors-grid-sec wrap">
  <div class="interiors-grid" id="intGrid">
    
    <!-- Item 1 -->
    <article class="int-card" data-category="villas">
