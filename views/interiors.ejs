        <div class="materials-list">
          <span class="mat-chip">Acoustic Panels</span>
          <span class="mat-chip">Oak Veneer</span>
          <span class="mat-chip">Glass Partition</span>
        </div>
        <div class="card-foot">
          <a href="/contact?service=interior&ref=Udupi-Office" class="cta-btn">Enquire for This Design →</a>
        </div>
      </div>
    </article>

    <!-- Item 6 -->
    <article class="int-card" data-category="lounges">
      <div class="img-wrap">
        <img src="https://images.unsplash.com/photo-1617806118233-18e1de247200?auto=format&fit=crop&w=800&q=80" alt="Contemporary Dining Hall" loading="lazy">
        <span class="tag-badge">Penthouse Lounge</span>
      </div>
      <div class="card-body">
        <h3>Minimalist Dining &amp; Wine Gallery</h3>
        <div class="location">📍 Surathkal · 800 sq ft</div>
        <p class="desc">Sculptural 10-seater marble dining table flanked by custom climate-controlled glass wine display cabinets and ambient brass pendants.</p>
        <div class="materials-list">
