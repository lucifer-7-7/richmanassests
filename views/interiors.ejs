        <div class="materials-list">
          <span class="mat-chip">Quartz Island</span>
          <span class="mat-chip">Blum Fittings</span>
          <span class="mat-chip">Brushed Brass</span>
        </div>
        <div class="card-foot">
          <a href="/contact?service=interior&ref=Manipal-Kitchen" class="cta-btn">Enquire for This Design →</a>
        </div>
      </div>
    </article>

    <!-- Item 3 -->
    <article class="int-card" data-category="lounges">
      <div class="img-wrap">
        <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=800&q=80" alt="Penthouse Terrace Lounge" loading="lazy">
        <span class="tag-badge">Penthouse Lounge</span>
      </div>
      <div class="card-body">
        <h3>Sunset Sky Terrace &amp; Lounge</h3>
        <div class="location">📍 Mangaluru Penthouse · 1,200 sq ft</div>
        <p class="desc">Bespoke rooftop sky lounge featuring weather-resistant wicker seating, fluted wooden wall panelling, and an outdoor brass wet bar.</p>
        <div class="materials-list">
          <span class="mat-chip">Teak Decking</span>
          <span class="mat-chip">Weatherproof Wicker</span>
          <span class="mat-chip">Ambient LEDs</span>
        </div>
        <div class="card-foot">
          <a href="/contact?service=interior&ref=Mangaluru-Penthouse" class="cta-btn">Enquire for This Design →</a>
        </div>
      </div>
    </article>

    <!-- Item 4 -->
    <article class="int-card" data-category="villas">
      <div class="img-wrap">
        <img src="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=800&q=80" alt="Coastal Teak Bedroom Suite" loading="lazy">
        <span class="tag-badge">Coastal Villa</span>
      </div>
      <div class="card-body">
        <h3>Heritage Teak Master Suite</h3>
        <div class="location">📍 Mulki Backwaters · 650 sq ft</div>
