<!-- LOANS -->
<section class="loans-cta" data-screen-label="Loans">
  <div class="wrap"><div class="loans-in">
    <div>
      <span class="kicker" style="color:var(--gold)"><span class="gold-line"></span>Home &amp; project loans</span>
      <h2>Found the home. <span class="it">We will find the loan.</span></h2>
      <p>Pre-approved offers from our partner banks, eligibility advice, and custom rates from public sector and private sector banks negotiated directly.</p>
      
      <div class="emi-pane" style="background:none;border:0;padding:0;margin-top:24px">
        <div class="emi-ctrl" style="margin-bottom:18px">
          <div class="top" style="display:flex;justify-content:space-between;color:rgba(0, 0, 0, 0.88);font-size:12px;margin-bottom:6px">
            <span style="font-family:var(--f-mono);text-transform:uppercase;letter-spacing:.1em;color: black;">Loan Amount</span>
            <span style="font-weight:600;font-size:16px" id="slideAmtVal">₹50 L</span>
          </div>
          <input type="range" id="slideAmount" min="500000" max="50000000" step="500000" value="5000000" style="width:100%;height:3px;background:rgba(0, 0, 0, 0.2);border-radius:2px;outline:none;-webkit-appearance:none;appearance:none">
        </div>
        <div class="emi-ctrl" style="margin-bottom:18px">
          <div class="top" style="display:flex;justify-content:space-between;color:rgba(0, 0, 0, 0.88);font-size:12px;margin-bottom:6px">
            <span style="font-family:var(--f-mono);text-transform:uppercase;letter-spacing:.1em;color: black">Tenure</span>
            <span style="font-weight:600;font-size:16px" id="slideTenureVal">20 Years</span>
          </div>
          <input type="range" id="slideTenure" min="5" max="30" step="1" value="20" style="width:100%;height:3px;background:rgba(0, 0, 0, 0.2);border-radius:2px;outline:none;-webkit-appearance:none;appearance:none">
        </div>
        <div class="emi-ctrl" style="margin-bottom:24px">
          <div class="top" style="display:flex;justify-content:space-between;color:rgba(4, 4, 4, 0.88);font-size:12px;margin-bottom:6px">
            <span style="font-family:var(--f-mono);text-transform:uppercase;letter-spacing:.1em;color: black">Interest Rate</span>
            <span style="font-weight:600;font-size:16px" id="slideRateVal">8.5% p.a.</span>
          </div>
          <input type="range" id="slideRate" min="7" max="15" step="0.1" value="8.5" style="width:100%;height:3px;background:rgba(0, 0, 0, 0.2);border-radius:2px;outline:none;-webkit-appearance:none;appearance:none">
        </div>
      </div>
      
      <div class="loans-actions" style="margin-top:20px">
        <a class="btn btn-dark" href="/contact?service=loans"><span>Get loan quotes</span><span class="arr">→</span></a>
        <a class="btn btn-ghost" href="/loans" style="border-color:rgba(247,244,237,.24);color:var(--paper)"><span>Eligibility terms</span></a>
      </div>
    </div>
    <div class="emi-out" style="display:flex;flex-direction:column;justify-content:center;height:100%">
      <div class="lab" style="color:rgba(247,244,237,.56)">Estimated Monthly EMI</div>
      <div class="big" style="color:var(--gold);margin:14px 0" id="homeEmiVal">₹43,<span class="it">391</span></div>
      <div class="split" style="border-top-color:rgba(247,244,237,.14)">
        <div><div class="v" id="homeEmiTotal">₹1.04 Cr</div><div class="k" style="color:rgba(247,244,237,.48)">Total Payable</div></div>
        <div><div class="v" id="homeEmiInterest">₹54 L</div><div class="k" style="color:rgba(247,244,237,.48)">Total Interest</div></div>
      </div>
    </div>
  </div></div>
</section>

