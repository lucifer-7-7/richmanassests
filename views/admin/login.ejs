<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin Login · RichManAssets</title>
<meta name="robots" content="noindex,nofollow"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Inter',system-ui,sans-serif;background:#F7F5F2;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
  .wrap{width:100%;max-width:400px}
  .logo-row{text-align:center;margin-bottom:32px}
  .logo{font-size:22px;font-weight:700;color:#17150F;letter-spacing:-.02em}
  .logo-badge{display:inline-block;font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:#908A7C;border:1px solid #E2DDD6;padding:3px 9px;border-radius:100px;margin-left:8px;font-weight:500;vertical-align:2px}
  .box{background:#fff;border:1px solid #E2DDD6;border-radius:16px;padding:36px 32px;box-shadow:0 2px 16px rgba(23,21,15,.07)}
  h1{font-size:20px;font-weight:700;color:#17150F;margin-bottom:4px}
  .sub{font-size:13.5px;color:#908A7C;margin-bottom:26px}
  label{display:block;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:#3B362C;margin-bottom:6px;font-weight:600}
  input[type=password]{
    width:100%;padding:12px 14px;
    border:1px solid #E2DDD6;border-radius:8px;
    font:15px 'Inter',system-ui;color:#17150F;outline:none;
    transition:border-color .15s,box-shadow .15s;background:#fff
  }
  input[type=password]:focus{border-color:#9A7B3F;box-shadow:0 0 0 3px rgba(154,123,63,.10)}
  .err{color:#C0392B;font-size:13px;margin-bottom:16px;padding:11px 14px;background:#FDF2F1;border:1px solid rgba(192,57,43,.18);border-radius:7px;display:flex;align-items:center;gap:8px}
  button{width:100%;margin-top:18px;padding:13px;background:#17150F;color:#fff;border:0;border-radius:8px;font:600 14px 'Inter',system-ui;letter-spacing:.02em;cursor:pointer;transition:background .2s}
  button:hover{background:#9A7B3F}
  .back{display:block;text-align:center;margin-top:18px;font-size:13px;color:#908A7C;text-decoration:none}
  .back:hover{color:#17150F}
</style>
</head>
<body>
<div class="wrap">
  <div class="logo-row">
    <span class="logo">RichManAssets</span><span class="logo-badge">Admin</span>
  </div>
  <div class="box">
    <h1>Sign in</h1>
    <p class="sub">Enter your admin password to continue.</p>
    <% if (flash) { %><div class="err">⚠ <%= flash %></div><% } %>
    <form method="post" action="/admin/login">
      <label for="admin-pw">Password</label>
      <input type="password" id="admin-pw" name="password" autofocus autocomplete="current-password" required>
      <button type="submit">Sign in →</button>
    </form>
  </div>
  <a href="/" class="back">← Back to site</a>
</div>
</body>
</html>
