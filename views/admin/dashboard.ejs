<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin · RichManAssets</title>
<meta name="robots" content="noindex,nofollow"/>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..600;1,6..72,400&family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:          #F6F2EC;
  --white:       #FFFFFF;
  --surface:     #FFFFFF;
  --surface2:    #F3EFE9;
  --ink:         #1C1917;
  --ink-2:       #44403C;
  --muted:       #8C8275;
  --muted2:      #B5ABA0;
  --line:        #E2DBD0;
  --line2:       #EAE4DC;
  --accent:      #1C1917;
  --gold:        #B5934C;
  --gold-bg:     #FBF6EB;
  --nude:        #E8E2D8;
  --ok-bg:       #F0FAF4;--ok:#27694A;
  --err-bg:      #FDF2F2;--err:#D93838;
  --r:           20px;
  --r-sm:        12px;
  --r-pill:      999px;
  --shadow:      none;
  --shadow-lg:   none;
}
body{font-family:'Inter','Plus Jakarta Sans',system-ui,sans-serif;background:var(--bg);color:var(--ink);font-size:14px;min-height:100svh;-webkit-font-smoothing:antialiased}

/* ── TOP BAR ── */
.top{background:var(--white);color:var(--ink);height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;position:sticky;top:0;z-index:50;border-bottom:1px solid var(--line)}
.top .brand{font-size:17px;font-weight:800;letter-spacing:-.03em;color:var(--ink);display:flex;align-items:center;gap:10px}
.top .brand .badge{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);border:1px solid var(--line);padding:3px 9px;border-radius:var(--r-pill);font-weight:700}
.top .nav-links{display:flex;gap:6px;align-items:center}
.top .nav-links a{color:var(--ink);font-size:13px;text-decoration:none;padding:8px 16px;border-radius:var(--r-pill);transition:.18s;font-weight:600;background:var(--nude);white-space:nowrap!important;display:inline-flex;align-items:center}
.top .nav-links a:hover{background:var(--ink);color:#fff}
.top .nav-links .sign-out{color:var(--muted);background:transparent}
.top .nav-links .sign-out:hover{color:var(--err);background:var(--err-bg)}

@media (max-width:768px) {
  .top{padding:0 12px;height:56px}
  .top .brand{font-size:14px;gap:6px}
  .top .brand .badge{font-size:8px;padding:2px 6px}
  .top .nav-links a{font-size:11.5px;padding:6px 12px;white-space:nowrap!important}
  .top .nav-links .sign-out{font-size:11.5px;padding:6px 8px}
  .desktop-table-wrap{display:none!important}
  .mobile-card-list{display:flex!important;flex-direction:column;gap:12px}
}
@media (min-width:769px) {
  .mobile-card-list{display:none!important}
  .desktop-table-wrap{display:block!important}
}

/* ── LAYOUT ── */
.layout{display:flex;min-height:calc(100svh - 64px)}
.sidebar{
  width:248px;flex:none;background:var(--white);border-right:1px solid var(--line);
  padding:20px 14px;display:flex;flex-direction:column;gap:5px;
  position:sticky;top:64px;height:calc(100svh - 64px);overflow-y:auto;
}
.sidebar button{
  display:flex;align-items:center;gap:11px;
  padding:11px 16px;border-radius:var(--r-pill);
  font-size:13.5px;font-weight:600;color:var(--ink-2);text-decoration:none;
  transition:all .18s cubic-bezier(0.16, 1, 0.3, 1);background:none;border:0;cursor:pointer;width:100%;text-align:left;
}
.sidebar button:hover{background:var(--surface2);color:var(--ink)}
.sidebar button.active{background:var(--ink);color:#FFFFFF;font-weight:700;}
.sidebar .icon{width:18px;height:18px;flex:none;opacity:.6}
.sidebar button.active .icon{opacity:1;color:#FFFFFF}
.sidebar .sec-label{font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding:16px 14px 6px;font-weight:800}
.sidebar .count-badge{margin-left:auto;background:var(--gold);color:#FFFFFF;font-size:10.5px;font-weight:800;padding:2px 8px;border-radius:var(--r-pill)}

.content{flex:1;padding:32px 28px;max-width:1160px;overflow:hidden}

/* mobile: sidebar drawer */
@media(max-width:768px){
  .sidebar{
    display: flex;
    position: fixed;
    top: 64px;
    left: -260px;
    width: 248px;
    height: calc(100svh - 64px);
    z-index: 99;
    box-shadow: 4px 0 24px rgba(0,0,0,.08);
    transition: left .25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sidebar.open { left: 0; }
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 64px 0 0 0;
    background: rgba(0,0,0,0.25);
    z-index: 98;
    backdrop-filter: blur(4px);
  }
  .sidebar-overlay.open { display: block; }
  .top .menu-toggle { display: flex !important; }
  .content{padding:20px 16px 80px}
}

/* ── FLASH ── */
.flash{padding:14px 18px;border-radius:var(--r-sm);margin-bottom:24px;font-size:13.5px;font-weight:600;display:flex;align-items:center;gap:10px}
.flash.ok{background:var(--ok-bg);color:var(--ok);border:1px solid rgba(45,138,86,0.18)}
.flash.err{background:var(--err-bg);color:var(--err);border:1px solid rgba(224,62,62,0.18)}

/* ── PANELS ── */
.panel{display:none}.panel.active{display:block}

/* ── STAT CARDS ── */
.stats-row{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:28px}
@media(min-width:768px){.stats-row{grid-template-columns:repeat(4,1fr)}}
.stat-card{background:var(--white);border:1px solid var(--line);border-radius:var(--r);padding:22px 24px;transition:border-color .18s}
.stat-card:hover{border-color:var(--muted)}
.stat-card .v{font-size:34px;font-weight:800;line-height:1;letter-spacing:-.03em;color:var(--ink)}
.stat-card .l{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:8px;font-weight:700}
.stat-card.accent .v{color:var(--gold)}

/* ── PROPERTY CARDS ── */
.prop-grid{display:grid;grid-template-columns:1fr;gap:16px}
@media(min-width:540px){.prop-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:960px){.prop-grid{grid-template-columns:repeat(3,1fr)}}
.prop-card{background:var(--white);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;transition:border-color .18s}
.prop-card:hover{border-color:var(--muted)}
.prop-card .thumb{position:relative;aspect-ratio:16/10;background:var(--surface2);overflow:hidden}
.prop-card .thumb img{width:100%;height:100%;object-fit:cover}
.prop-card .thumb .no-img{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700}
.prop-card .thumb .listing-badge{position:absolute;bottom:10px;left:10px;font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:5px 12px;border-radius:var(--r-pill);color:#fff;font-weight:800}
.prop-card .thumb .listing-badge.sale{background:#111113}
.prop-card .thumb .listing-badge.rent{background:#2563EB}
.prop-card .thumb .listing-badge.lease{background:#7C3AED}
.prop-card .thumb .status-dot{position:absolute;top:10px;right:10px;width:10px;height:10px;border-radius:50%;border:2px solid #fff}
.prop-card .thumb .status-dot.active{background:#22C55E}
.prop-card .thumb .status-dot.hidden{background:#9CA3AF}
.prop-card .info{padding:18px}
.prop-card .info .price{font-size:19px;font-weight:800;letter-spacing:-.02em;line-height:1;color:var(--ink)}
.prop-card .info .name{font-size:14.5px;font-weight:700;margin-top:5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--ink)}
.prop-card .info .loc{font-size:12px;color:var(--muted);margin-top:4px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.prop-card .actions{display:flex;gap:8px;padding:0 18px 18px}
.prop-card .actions a,.prop-card .actions button{
  flex:1;padding:9px 6px;border-radius:var(--r-pill);font-size:12.5px;font-weight:700;
  text-align:center;border:0;cursor:pointer;text-decoration:none;transition:all .18s;display:block;
}
.prop-card .actions .a-edit{background:var(--ink);color:#fff}
.prop-card .actions .a-edit:hover{background:var(--accent-hover)}
.prop-card .actions .a-toggle{background:var(--surface2);color:var(--ink-2)}
.prop-card .actions .a-toggle:hover{background:var(--ink);color:#fff}
.prop-card .actions .a-del{background:var(--err-bg);color:var(--err)}
.prop-card .actions .a-del:hover{background:var(--err);color:#fff}
.prop-card .actions .a-view{background:var(--surface2);color:var(--ink-2)}
.prop-card .actions .a-view:hover{background:var(--ink);color:#fff}

/* buttons & pill filter controls */
.add-btn{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:#fff;padding:11px 22px;border-radius:var(--r-pill);font-size:13.5px;font-weight:700;cursor:pointer;border:0;transition:background .18s;text-decoration:none}
.add-btn:hover{background:var(--accent-hover)}
.add-btn svg{width:16px;height:16px}

.list-controls{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;align-items:center}
.list-controls input,.list-controls select{
  background:var(--white);border:1px solid var(--line);border-radius:var(--r-pill);
  padding:11px 18px;font:inherit;font-size:13.5px;font-weight:500;color:var(--ink);outline:none;
  transition:all .18s;
}
.list-controls input:focus,.list-controls select:focus{border-color:var(--ink);box-shadow:0 0 0 3px rgba(15,15,18,0.06)}
.list-controls input{flex:1;min-width:180px}

/* ── ENQUIRY CARDS ── */
.enq-list{display:flex;flex-direction:column;gap:14px}
.enq-card{background:var(--white);border:1px solid var(--line);border-radius:var(--r);padding:22px;display:grid;gap:12px;position:relative;transition:border-color .18s}
.enq-card.unread{border-left:5px solid var(--gold);background:#FFFCF5}
.enq-card .enq-top{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.enq-card .enq-name{font-weight:800;font-size:15px;color:var(--ink);display:flex;align-items:center;gap:10px}
.enq-card .enq-date{font-size:12px;color:var(--muted);font-weight:500;flex:none}
.enq-card .enq-contact{display:flex;gap:14px;flex-wrap:wrap;padding-bottom:2px}
.enq-card .enq-contact a{font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;display:inline-flex;align-items:center;gap:5px;background:var(--surface2);padding:5px 12px;border-radius:var(--r-pill)}
.enq-card .enq-contact a:hover{background:var(--ink);color:#FFFFFF}
.enq-card .enq-body{font-size:14px;color:var(--ink-2);line-height:1.6;background:var(--surface2);padding:12px 16px;border-radius:var(--r-sm);margin:2px 0;font-weight:500}
.enq-card .enq-tags{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.enq-tag{font-size:11px;font-weight:700;padding:4px 12px;border-radius:var(--r-pill);background:var(--surface2);color:var(--ink-2);font-family:inherit}
.enq-tag.prop{background:var(--gold-bg);color:var(--gold);font-weight:700;text-decoration:none}
.enq-tag.unread-badge{background:var(--gold);color:#fff;font-weight:800}
.enq-card .actions{display:flex;gap:8px;justify-content:flex-end;margin-top:4px;padding-top:12px;border-top:1px dashed var(--line)}
.enq-card .actions form{display:inline-flex}
.enq-card .actions button{padding:8px 16px;border-radius:var(--r-pill);font-size:12.5px;font-weight:700;cursor:pointer;border:0;transition:.18s;display:inline-flex;align-items:center;gap:4px}
.enq-card .actions .btn-toggle{background:var(--surface2);color:var(--ink-2)}
.enq-card .actions .btn-toggle:hover{background:var(--ink);color:#fff}
.enq-card .actions .btn-delete{background:var(--err-bg);color:var(--err)}
.enq-card .actions .btn-delete:hover{background:var(--err);color:#fff}

/* ── ADD / EDIT FORM ── */
.form-card{background:var(--white);border:1px solid var(--line);border-radius:var(--r);padding:clamp(22px,4vw,36px)}
.form-section{margin-bottom:28px;padding-bottom:28px;border-bottom:1px solid var(--line2)}
.form-section:last-child{border-bottom:0;margin-bottom:0;padding-bottom:0}
.form-section-title{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);font-weight:800;margin-bottom:16px}
.fg{display:grid;gap:14px;grid-template-columns:1fr}
@media(min-width:540px){.fg{grid-template-columns:1fr 1fr}}
@media(min-width:900px){.fg.cols3{grid-template-columns:1fr 1fr 1fr}}
.fg.full{grid-template-columns:1fr!important}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:6px}
.field label{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-2);font-weight:700;margin-top:4px}
.field input,.field select,.field textarea{
  padding:13px 16px;border:1.5px solid var(--line);border-radius:var(--r-sm);
  font:inherit;font-size:14px;font-weight:500;color:var(--ink);outline:none;transition:border-color .18s, box-shadow .18s;
  background:var(--white);-webkit-appearance:none;
}
.field input:focus,.field select:focus,.field textarea:focus{background:var(--white);border-color:var(--ink);box-shadow:0 0 0 3.5px rgba(28,25,23,0.08)}
.field textarea{resize:vertical;min-height:100px}
.field small,.form-hint{display:block;font-size:12px;color:var(--muted);font-weight:500;margin-top:5px;margin-bottom:14px;line-height:1.4}
input[type=file] {
  padding: 10px 14px; background: var(--surface2); border: 1px solid var(--line);
  border-radius: var(--r-sm); font: 13px inherit; font-weight: 500; color: var(--ink-2);
  width: 100%; cursor: pointer;
}
input[type=file]::file-selector-button,
input[type=file]::-webkit-file-upload-button {
  background: var(--ink); color: #FFFFFF; font-family: inherit; font-weight: 700;
  font-size: 12px; border-radius: var(--r-pill); border: 0; padding: 7px 16px;
  margin-right: 12px; cursor: pointer; transition: background .18s;
}
input[type=file]::file-selector-button:hover,
input[type=file]::-webkit-file-upload-button:hover { background: var(--accent-hover); }
.img-preview{width:100%;max-height:180px;object-fit:cover;border-radius:var(--r-sm);margin-top:8px;display:none}
.img-preview.show{display:block}
.form-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:24px}
.btn-save{padding:13px 28px;background:var(--ink);color:#fff;border:0;border-radius:var(--r-pill);font:inherit;font-size:14px;font-weight:700;cursor:pointer;transition:.2s;box-shadow:0 4px 14px rgba(0,0,0,0.12)}
.btn-save:hover{background:var(--accent-hover);transform:translateY(-1px)}
.btn-cancel{padding:13px 22px;background:var(--surface2);border:1px solid transparent;border-radius:var(--r-pill);font:inherit;font-size:14px;font-weight:700;color:var(--ink-2);cursor:pointer;transition:.18s;text-decoration:none;display:inline-flex;align-items:center}
.btn-cancel:hover{background:var(--ink);color:#fff}
.page-head{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:24px;flex-wrap:wrap}
.page-head h1{font-family:'Newsreader',serif;font-size:clamp(24px,3.5vw,32px);font-weight:500;letter-spacing:-.01em;color:var(--ink)}
.empty{text-align:center;padding:56px 20px;color:var(--muted)}
.empty h3{font-family:'Newsreader',serif;font-size:22px;font-weight:500;color:var(--ink);margin-bottom:6px}
</style>
</head>
<body>

<div class="top">
  <div class="brand" style="gap:12px">
    <button class="menu-toggle" onclick="toggleSidebar()" style="display:none;background:none;border:0;color:var(--ink);cursor:pointer;padding:4px;align-items:center;justify-content:center">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    RichManAssets
    <span class="badge">Admin</span>
  </div>
  <div class="nav-links">
    <a href="/" target="_blank">View site ↗</a>
    <a href="/admin/logout" class="sign-out">Sign out</a>
  </div>
</div>

<div class="layout">
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
  <!-- Desktop sidebar -->
  <nav class="sidebar" id="adminSidebar">
    <span class="sec-label">Manage</span>
    <button class="active" onclick="showPanel('properties')" id="sb-properties">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h3a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h3a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
      Properties
    </button>
    <button onclick="showPanel('add')" id="sb-add">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      Add property
    </button>
    <button onclick="showPanel('enquiries')" id="sb-enquiries">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
      Enquiries
      <% if (stats.unreadEnquiries > 0) { %><span class="count-badge"><%= stats.unreadEnquiries %></span><% } %>
    </button>
    <button onclick="showPanel('agent-listings')" id="sb-agent-listings">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
      Agent Listings
      <% if (stats.agentPublished > 0) { %><span class="count-badge" style="background:#2D8A56"><%= stats.agentPublished %></span><% } %>
    </button>
    <button onclick="showPanel('agents')" id="sb-agents">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
      Agents
      <% if ((stats.totalAgents||0) > 0) { %><span class="count-badge" style="background:var(--muted)"><%= stats.totalAgents %></span><% } %>
    </button>
    <button onclick="showPanel('payments')" id="sb-payments">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/></svg>
      Payments
    </button>
    <button onclick="showPanel('webhooks')" id="sb-webhooks">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 3a1 1 0 00-1.414-1.414l-3 3A1 1 0 0013 5.293V6H5a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-5a1 1 0 10-2 0v5H5V8h8v.707a1 1 0 001.707.707l3-3z" clip-rule="evenodd"/></svg>
      Webhook Logs
    </button>
    <button onclick="showPanel('settings')" id="sb-settings">
      <svg class="icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.532 1.532 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.532 1.532 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
      Promo Ad Banner
    </button>

    <span class="sec-label" style="margin-top:12px">Overview</span>
    <div style="padding:14px 16px;background:var(--surface2);border-radius:var(--r-sm);display:flex;flex-direction:column;gap:10px">
      <div style="display:flex;justify-content:space-between;font-size:12.5px;font-weight:600"><span style="color:var(--muted)">Admin Props</span><b><%= stats.active %>/<%= stats.total %></b></div>
      <div style="display:flex;justify-content:space-between;font-size:12.5px;font-weight:600"><span style="color:var(--muted)">Agent Published</span><b><%= stats.agentPublished||0 %></b></div>
      <div style="display:flex;justify-content:space-between;font-size:12.5px;font-weight:600"><span style="color:var(--muted)">Agents</span><b><%= stats.totalAgents||0 %></b></div>
      <div style="display:flex;justify-content:space-between;font-size:12.5px;font-weight:600"><span style="color:var(--muted)">Enquiries</span><b><%= stats.enquiries %></b></div>
    </div>
  </nav>

  <!-- Main content -->
  <main class="content">
    <% if (flash) { %>
    <div class="flash <%= flash.type === 'ok' ? 'ok' : 'err' %>">
      <%= flash.type === 'ok' ? '✓' : '!' %> <%= flash.msg %>
    </div>
    <% } %>

    <!-- PROPERTIES PANEL -->
    <div class="panel active" id="panel-properties">
      <div class="page-head">
        <h1>Properties</h1>
        <button class="add-btn" onclick="showPanel('add')">
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
          Add new
        </button>
      </div>

      <div class="list-controls">
        <input type="text" id="searchProp" placeholder="Search by name or location…" oninput="filterProps()">
        <select id="filterListing" onchange="filterProps()">
          <option value="">All types</option>
          <option value="sale">For Sale</option>
          <option value="rent">For Rent</option>
          <option value="lease">For Lease</option>
        </select>
      </div>

      <% if (properties.length === 0) { %>
      <div class="empty">
        <h3>No properties yet</h3>
        <p>Add your first property to get started.</p>
      </div>
      <% } else { %>
      <div class="prop-grid" id="propGrid">
        <% properties.forEach(function(p) { %>
        <div class="prop-card" data-name="<%= (p.name + ' ' + p.loc).toLowerCase() %>" data-listing="<%= p.listing %>">
          <div class="thumb">
            <% if (p.img_card || p.img_hero) { %>
            <img src="/<%= p.img_card || p.img_hero %>" alt="<%= p.name %>" loading="lazy">
            <% } else { %><div class="no-img">No photo</div><% } %>
            <span class="listing-badge <%= p.listing %>"><%= p.listing === 'sale' ? 'Sale' : p.listing === 'rent' ? 'Rent' : 'Lease' %></span>
            <span class="status-dot <%= p.active ? 'active' : 'hidden' %>" title="<%= p.active ? 'Active' : 'Hidden' %>"></span>
          </div>
          <div class="info">
            <div class="price"><%= p.price %><% if (p.price_note) { %><span style="font-size:12px;font-weight:500;color:var(--muted)"> <%= p.price_note %></span><% } %></div>
            <div class="name"><%= p.name %></div>
            <div class="loc"><%= p.loc %> · <%= p.type %></div>
          </div>
          <div class="actions">
            <a class="a-edit" href="/admin/property/<%= p.id %>/edit">Edit</a>
            <a class="a-view" href="/property/<%= p.id %>" target="_blank">View</a>
            <form method="post" action="/admin/property/<%= p.id %>/toggle" style="flex:1;display:contents">
              <button class="a-toggle" type="submit"><%= p.active ? 'Hide' : 'Show' %></button>
            </form>
            <form method="post" action="/admin/property/<%= p.id %>/delete" onsubmit="return confirm('Delete <%= p.name %>?')" style="flex:1;display:contents">
              <button class="a-del" type="submit">Del</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- ADD PROPERTY PANEL -->
    <div class="panel" id="panel-add">
      <div class="page-head">
        <h1>Add property</h1>
        <button class="btn-cancel" onclick="showPanel('properties')">← Back</button>
      </div>
      <div class="form-card">
        <form method="post" action="/admin/property" enctype="multipart/form-data" id="addForm">

          <div class="form-section">
            <div class="form-section-title">Basic info</div>
            <div class="fg">
              <div class="field"><label>Property name *</label><input name="name" required placeholder="e.g. Villa Mermaid" id="nameField"></div>
              <div class="field"><label>Slug / URL ID *</label><input name="id" required placeholder="e.g. mermaid" pattern="[a-z0-9\-]+" id="slugField"><small>Used in URL: /property/slug</small></div>
            </div>
            <div class="fg cols3">
              <div class="field"><label>Location *</label><input name="loc" required placeholder="e.g. Mulki Backwaters"></div>
              <div class="field"><label>Area</label><input name="area" placeholder="e.g. Mulki"></div>
              <div class="field"><label>Property type *</label>
                <select name="type" required>
                  <option value="">Select…</option>
                  <option>Villa</option><option>House</option><option>Estate</option>
                  <option>Apartment</option><option>Plot</option><option>Commercial</option><option>Agricultural</option>
                </select>
              </div>
            </div>
            <div class="fg cols3">
              <div class="field"><label>Listing *</label>
                <select name="listing" required>
                  <option value="">Select…</option>
                  <option value="sale">For Sale</option>
                  <option value="rent">For Rent</option>
                  <option value="lease">For Lease</option>
                </select>
              </div>
              <div class="field"><label>Price *</label><input name="price" required placeholder="e.g. ₹7.5 Cr"></div>
              <div class="field"><label>Price suffix</label><input name="price_note" placeholder="e.g. /month"></div>
            </div>
            <div class="fg cols3">
              <div class="field"><label>Beds</label><input name="beds" placeholder="e.g. 4"></div>
              <div class="field"><label>Baths</label><input name="baths" placeholder="e.g. 4"></div>
              <div class="field"><label>Area / sqft</label><input name="sqft" placeholder="e.g. 4,200 or 3 acres"></div>
            </div>
            <div class="fg">
              <div class="field"><label>Subtype</label><input name="subtype" placeholder="e.g. Event venue, Builder project"></div>
              <div class="field"><label>Price value (for filters)</label><input name="price_val" type="number" placeholder="e.g. 7500000"></div>
            </div>
          </div>

          <div class="form-section">
            <div class="form-section-title">Story & content</div>
            <div class="fg full">
              <div class="field"><label>Kicker line</label><input name="story_kicker" placeholder="e.g. Where the river bends"></div>
              <div class="field"><label>Heading</label><input name="story_heading" placeholder="e.g. A house that leans out over the water."></div>
              <div class="field"><label>Story (separate paragraphs with blank line)</label><textarea name="story_body" rows="5" placeholder="Describe the property…"></textarea></div>
              <div class="field">
                <label>Amenities <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:11px;color:var(--muted)">(type and press Enter or comma)</span></label>
                <div class="tag-input" id="amen-tags-add" data-target="amenities-add"></div>
                <input type="hidden" name="amenities" id="amenities-add">
              </div>
              <div class="field"><label>Setting heading</label><input name="setting_heading" placeholder="e.g. Mulki Backwaters"></div>
              <div class="field"><label>Setting description</label><textarea name="setting_body" rows="3" placeholder="Describe the location…"></textarea></div>
              <div class="field">
                <label>Location pills <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:11px;color:var(--muted)">(type and press Enter or comma)</span></label>
                <div class="tag-input" id="pills-tags-add" data-target="setting_pills-add"></div>
                <input type="hidden" name="setting_pills" id="setting_pills-add">
              </div>
            </div>
          </div>

          <div class="form-section">
            <div class="form-section-title">Images</div>
            <div class="fg">
              <div class="field">
                <label>Card image (thumbnail)</label>
                <input type="file" name="img_card" accept="image/jpeg,image/png,image/webp" onchange="previewImg(this,'prev-card-add')">
                <img id="prev-card-add" class="img-preview" alt="">
                <small>800×600 JPG recommended · shown in listing grids</small>
              </div>
              <div class="field">
                <label>Hero image (full-width)</label>
                <input type="file" name="img_hero" accept="image/jpeg,image/png,image/webp" onchange="previewImg(this,'prev-hero-add')">
                <img id="prev-hero-add" class="img-preview" alt="">
                <small>1600×900 JPG recommended · shown at top of property page</small>
              </div>
            </div>
            <div class="field" style="margin-top:12px">
              <label>Gallery images <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:11px;color:var(--muted)">(up to 10 images, shown in photo strip on property page)</span></label>
              <input type="file" name="gallery" multiple accept="image/jpeg,image/png,image/webp" onchange="previewGallery(this,'gallery-prev-add')">
              <div class="gallery-prev" id="gallery-prev-add"></div>
              <small>1200×800 JPG recommended · select multiple files at once</small>
            </div>
          </div>

          <div class="form-section">
            <div class="form-section-title">Settings</div>
            <div class="fg cols3">
              <div class="field"><label>Featured on homepage?</label>
                <select name="featured"><option value="0">No</option><option value="1">Yes</option></select>
              </div>
              <div class="field"><label>Sort order</label><input name="sort_order" type="number" value="99" min="1" max="999"></div>
              <div class="field"><label>EMI value</label><input name="emi_val" placeholder="e.g. ₹5,53,237"></div>
            </div>
          </div>

          <div class="form-actions">
            <button class="btn-save" type="submit">Save property →</button>
            <button class="btn-cancel" type="button" onclick="showPanel('properties')">Cancel</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ENQUIRIES PANEL -->
    <div class="panel" id="panel-enquiries">
      <div class="page-head">
        <h1>Enquiries <span style="font-size:14px;font-weight:500;color:var(--muted)">(<%= stats.enquiries %> total<% if (stats.unreadEnquiries > 0) { %>, <%= stats.unreadEnquiries %> unread<% } %>)</span></h1>
        
        <% if (stats.unreadEnquiries > 0) { %>
        <form method="post" action="/admin/enquiries/mark-all-read" style="display:inline">
          <button class="add-btn" type="submit" style="background:var(--gold)">✓ Mark all read</button>
        </form>
        <% } %>
      </div>

      <div class="list-controls" style="margin-bottom:20px">
        <input type="text" id="searchEnq" placeholder="Search by name, contact or message…" oninput="filterEnquiries()">
        <select id="filterEnqStatus" onchange="filterEnquiries()">
          <option value="">All statuses</option>
          <option value="unread">Unread only</option>
          <option value="read">Read only</option>
        </select>
      </div>

      <% if (enquiries.length === 0) { %>
      <div class="empty"><h3>No enquiries yet</h3><p>Form submissions will appear here.</p></div>
      <% } else { %>
      <div class="enq-list" id="enqGrid">
        <% enquiries.forEach(function(e) { %>
        <div class="enq-card <%= e.is_read ? '' : 'unread' %>" 
             data-name="<%= (e.name || 'Anonymous').toLowerCase() %>" 
             data-details="<%= ((e.phone || '') + ' ' + (e.email || '') + ' ' + (e.message || '') + ' ' + (e.budget || '') + ' ' + (e.property_ref || '')).toLowerCase() %>"
             data-read="<%= e.is_read ? '1' : '0' %>">
          <div class="enq-top">
            <div class="enq-name">
              <%= e.name || 'Anonymous' %>
              <% if (!e.is_read) { %><span class="enq-tag unread-badge">New</span><% } %>
            </div>
            <div class="enq-date"><%= new Date(e.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
          </div>
          <div class="enq-contact">
            <% if (e.phone) { %><a href="tel:<%= e.phone %>">📞 <%= e.phone %></a><% } %>
            <% if (e.email) { %><a href="mailto:<%= e.email %>">✉ <%= e.email %></a><% } %>
            <% if (e.phone) { %><a href="https://wa.me/<%= e.phone.replace(/\D/g,'') %>" target="_blank" rel="noopener">💬 WhatsApp</a><% } %>
          </div>
          <% if (e.message || e.budget) { %>
          <div class="enq-body"><%= e.message || e.budget %></div>
          <% } %>
          <div class="enq-tags">
            <% if (e.service) { %><span class="enq-tag"><%= e.service %></span><% } %>
            <% if (e.property_ref) { %><a class="enq-tag prop" href="/property/<%= e.property_ref %>" target="_blank">Ref: <%= e.property_ref %> ↗</a><% } %>
            <% if (e.time_pref && e.time_pref !== 'Anytime') { %><span class="enq-tag">Call: <%= e.time_pref %></span><% } %>
          </div>
          <div class="actions">
            <form method="post" action="/admin/enquiries/<%= e.id %>/toggle-read">
              <button class="btn-toggle" type="submit">
                <%= e.is_read ? 'Mark Unread' : 'Mark Read' %>
              </button>
            </form>
            <form method="post" action="/admin/enquiries/<%= e.id %>/delete" onsubmit="return confirm('Delete enquiry from <%= e.name || "Anonymous" %>?')">
              <button class="btn-delete" type="submit">Delete</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- AGENT LISTINGS PANEL -->
    <div class="panel" id="panel-agent-listings">
      <div class="page-head"><h1>Agent Listings</h1></div>
      <% if (!agentProps || agentProps.length === 0) { %>
      <div class="empty"><h3>No agent listings yet</h3><p>Listings appear here after agents submit and pay.</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13.5px;background:#fff;border-radius:22px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line)">
          <thead><tr style="background:var(--surface2)">
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Property</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Agent</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Type/For</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Status</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Expires</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Actions</th>
          </tr></thead>
          <tbody>
          <% agentProps.forEach(function(p) { %>
          <tr style="border-bottom:1px solid var(--line2)">
            <td style="padding:14px 18px">
              <div style="font-weight:700;color:var(--ink)"><%= p.name %></div>
              <div style="font-size:12px;color:var(--muted)"><%= p.loc %></div>
            </td>
            <td style="padding:14px 18px;font-size:13px">
              <b><%= p.agents ? p.agents.name : '—' %></b>
              <div style="font-size:11.5px;color:var(--muted)"><%= p.agents ? p.agents.email : '' %></div>
            </td>
            <td style="padding:14px 18px;font-size:13px;font-weight:600"><%= p.type %> · <%= p.listing %></td>
            <td style="padding:14px 18px">
              <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:700;background:<%= p.status==='published'?'#F0FAF4':p.status==='payment_failed'?'#FDF2F2':'#EFF0F4' %>;color:<%= p.status==='published'?'#2D8A56':p.status==='payment_failed'?'#E03E3E':'#8E8E93' %>">
                <%= p.status.replace(/_/g,' ') %>
              </span>
            </td>
            <td style="padding:14px 18px;font-size:12px;color:var(--muted);font-weight:500">
              <%= p.expires_at ? new Date(p.expires_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : '—' %>
            </td>
            <td style="padding:14px 18px">
              <div style="display:flex;gap:6px;flex-wrap:wrap">
                <% if (p.status === 'published') { %>
                <a href="/property/<%= p.id %>" target="_blank" style="padding:6px 14px;background:var(--surface2);border:0;border-radius:999px;font-size:12px;font-weight:700;text-decoration:none;color:var(--ink)">View ↗</a>
                <form method="post" action="/admin/agent-listings/<%= p.id %>/archive" style="display:inline">
                  <button type="submit" style="padding:6px 14px;background:#FFF8EC;border:0;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;color:#D97706">Archive</button>
                </form>
                <% if (p.paid_order_id) { %>
                <form method="post" action="/admin/agent-listings/<%= p.id %>/refund" style="display:inline" onsubmit="return confirm('Refund ₹999 to agent?')">
                  <input type="hidden" name="reason" value="Admin initiated refund">
                  <button type="submit" style="padding:6px 14px;background:#FDF2F2;border:0;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;color:#E03E3E">Refund</button>
                </form>
                <% } %>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- AGENTS PANEL -->
    <div class="panel" id="panel-agents">
      <div class="page-head"><h1>Agents <span style="font-size:14px;font-weight:500;color:var(--muted)">(<%= stats.totalAgents||0 %> total)</span></h1></div>
      <% if (!agents || agents.length === 0) { %>
      <div class="empty"><h3>No agents registered yet</h3><p>Registered agents will appear here.</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13.5px;background:#fff;border-radius:22px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line)">
          <thead><tr style="background:var(--surface2)">
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Agent</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Status</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Registered</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Actions</th>
          </tr></thead>
          <tbody>
          <% agents.forEach(function(a) { %>
          <tr style="border-bottom:1px solid var(--line2)">
            <td style="padding:14px 18px">
              <div style="font-weight:700;color:var(--ink)"><%= a.name %></div>
              <div style="font-size:12px;color:var(--muted)"><%= a.email %></div>
            </td>
            <td style="padding:14px 18px">
              <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:700;background:<%= a.is_active?'#F0FAF4':'#FDF2F2' %>;color:<%= a.is_active?'#2D8A56':'#E03E3E' %>">
                <%= a.is_active ? 'Active' : 'Banned' %>
              </span>
            </td>
            <td style="padding:14px 18px;font-size:12px;color:var(--muted);font-weight:500">
              <%= new Date(a.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
            </td>
            <td style="padding:14px 18px">
              <form method="post" action="/admin/agents/<%= a.id %>/toggle" style="display:inline">
                <button type="submit" style="padding:6px 14px;background:<%= a.is_active?'#FDF2F2':'#F0FAF4' %>;border:0;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;color:<%= a.is_active?'#E03E3E':'#2D8A56' %>">
                  <%= a.is_active ? 'Ban Agent' : 'Activate' %>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- PAYMENTS PANEL -->
    <div class="panel" id="panel-payments">
      <div class="page-head"><h1>Payment Orders</h1></div>
      <% if (!orders || orders.length === 0) { %>
      <div class="empty"><h3>No payments yet</h3><p>Payments will appear here once agents make transactions.</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13.5px;background:#fff;border-radius:22px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line)">
          <thead><tr style="background:var(--surface2)">
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Order ID</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Agent</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Property</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Amount</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Method</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Status</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Date</th>
          </tr></thead>
          <tbody>
          <% orders.forEach(function(o) { %>
          <tr style="border-bottom:1px solid var(--line2)">
            <td style="padding:14px 18px;font-family:monospace;font-size:12px;font-weight:600"><%= o.internal_order_id %></td>
            <td style="padding:14px 18px">
              <b><%= o.agents ? o.agents.name : '—' %></b>
              <div style="font-size:11.5px;color:var(--muted)"><%= o.agents ? o.agents.email : '' %></div>
            </td>
            <td style="padding:14px 18px;font-weight:600"><%= o.agent_properties ? o.agent_properties.name : '—' %></td>
            <td style="padding:14px 18px;font-weight:800">₹<%= ((o.amount_paise||0)/100).toLocaleString('en-IN') %></td>
            <td style="padding:14px 18px"><%= o.payment_method || '—' %></td>
            <td style="padding:14px 18px">
              <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:700;background:<%= o.status==='paid'?'#F0FAF4':o.status==='failed'?'#FDF2F2':'#FFF8EC' %>;color:<%= o.status==='paid'?'#2D8A56':o.status==='failed'?'#E03E3E':'#D97706' %>">
                <%= o.status %>
              </span>
            </td>
            <td style="padding:14px 18px;font-size:12px;color:var(--muted);font-weight:500">
              <%= new Date(o.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    <!-- PROMO AD BANNER SETTINGS PANEL -->
    <div class="panel" id="panel-settings">
      <div class="page-head">
        <h1>Promotional Ad Banner Settings</h1>
      </div>
      
      <div class="form-card">
        <form method="post" action="/admin/settings/promo-banner">
          <div class="form-section">
            <div class="form-section-title">Banner Status &amp; Visibility</div>
            <div class="field" style="display:flex;flex-direction:row;align-items:center;gap:12px;margin-bottom:14px;">
              <input type="checkbox" id="pb_active" name="active" <%= promoBanner && promoBanner.active ? 'checked' : '' %> style="width:20px;height:20px;cursor:pointer;">
              <label for="pb_active" style="font-size:14px;font-weight:700;cursor:pointer;margin:0;">Enable Promotional Ad Banner on Home Page</label>
            </div>
            <div class="form-hint">When checked, the promotional banner will be displayed live on the homepage. Uncheck to hide it instantly.</div>
          </div>

          <div class="form-section">
            <div class="form-section-title">Banner Content &amp; Call To Action</div>
            <div class="fg">
              <div class="field">
                <label for="pb_kicker">Badge / Kicker Text</label>
                <input type="text" id="pb_kicker" name="kicker" value="<%= promoBanner ? promoBanner.kicker : 'EXCLUSIVE OFFER' %>" placeholder="e.g. MONSOON EXCLUSIVE OFFER">
              </div>
              <div class="field">
                <label for="pb_title">Main Headline</label>
                <input type="text" id="pb_title" name="title" value="<%= promoBanner ? promoBanner.title : '' %>" placeholder="e.g. Free 3D Interior Render with Every Listing">
              </div>
            </div>
            <div class="field">
              <label for="pb_subtitle">Subtitle / Supporting Description</label>
              <textarea id="pb_subtitle" name="subtitle" rows="3" placeholder="Explain the offer details..."><%= promoBanner ? promoBanner.subtitle : '' %></textarea>
            </div>
            <div class="fg cols3">
              <div class="field">
                <label for="pb_bg_img">Background Image URL</label>
                <input type="text" id="pb_bg_img" name="bg_img" value="<%= promoBanner ? promoBanner.bg_img : '' %>" placeholder="https://images.unsplash.com/...">
              </div>
              <div class="field">
                <label for="pb_cta_text">Button Label</label>
                <input type="text" id="pb_cta_text" name="cta_text" value="<%= promoBanner ? promoBanner.cta_text : 'Claim Offer →' %>" placeholder="e.g. Explore Showcase →">
              </div>
              <div class="field">
                <label for="pb_cta_link">Button Destination Link</label>
                <input type="text" id="pb_cta_link" name="cta_link" value="<%= promoBanner ? promoBanner.cta_link : '/interiors' %>" placeholder="e.g. /interiors or /contact">
              </div>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-save">Save Banner Settings →</button>
          </div>
        </form>
      </div>
    </div>

    <!-- WEBHOOKS PANEL -->
    <div class="panel" id="panel-webhooks">
      <div class="page-head"><h1>Webhook Logs</h1></div>
      <% if (!logs || logs.length === 0) { %>
      <div class="empty"><h3>No webhook logs yet</h3><p>Incoming logs appear here.</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13px;background:#fff;border-radius:22px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line)">
          <thead><tr style="background:var(--surface2)">
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Time</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Event</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">CF Order</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Sig Valid</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Processed</th>
            <th style="text-align:left;padding:14px 18px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--line)">Payload</th>
          </tr></thead>
          <tbody>
          <% logs.forEach(function(l) { %>
          <tr style="border-bottom:1px solid var(--line2)">
            <td style="padding:14px 18px;white-space:nowrap;color:var(--muted);font-weight:500"><%= new Date(l.received_at).toLocaleString('en-IN',{hour12:false}) %></td>
            <td style="padding:14px 18px;font-weight:700"><%= l.event_type || '—' %></td>
            <td style="padding:14px 18px;font-family:monospace"><%= l.cashfree_order_id || '—' %></td>
            <td style="padding:14px 18px">
              <span style="display:inline-flex;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;background:<%= l.sig_valid?'#F0FAF4':'#FDF2F2' %>;color:<%= l.sig_valid?'#2D8A56':'#E03E3E' %>">
                <%= l.sig_valid ? '✓' : '✗' %>
              </span>
            </td>
            <td style="padding:14px 18px">
              <span style="display:inline-flex;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;background:<%= l.processed?'#F0FAF4':'#FDF2F2' %>;color:<%= l.processed?'#2D8A56':'#E03E3E' %>">
                <%= l.processed ? 'Yes' : 'No' %>
              </span>
              <% if (l.processing_error) { %>
              <div style="font-size:11px;color:#E03E3E;margin-top:2px"><%= l.processing_error %></div>
              <% } %>
            </td>
            <td style="padding:14px 18px;font-family:monospace;font-size:11px;color:#555;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= l.payload %>">
              <%= l.payload.slice(0, 80) %>…
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </main>
</div>

<script>
function toggleSidebar() {
  const sidebar = document.getElementById('adminSidebar');
  const overlay = document.getElementById('sidebarOverlay');
  sidebar.classList.toggle('open');
  overlay.classList.toggle('open');
}

function showPanel(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar button').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  const sb = document.getElementById('sb-' + id);
  if (sb) sb.classList.add('active');
  
  // Close drawer on mobile
  const sidebar = document.getElementById('adminSidebar');
  const overlay = document.getElementById('sidebarOverlay');
  if (sidebar && sidebar.classList.contains('open')) {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
  }
  
  window.scrollTo(0,0);
}

function previewImg(input, previewId) {
  const file = input.files[0];
  if (!file) return;
  const img = document.getElementById(previewId);
  img.src = URL.createObjectURL(file);
  img.classList.add('show');
}

// auto-slug from name
const nameField = document.getElementById('nameField');
const slugField = document.getElementById('slugField');
if (nameField && slugField) {
  nameField.addEventListener('input', function() {
    if (!slugField.dataset.manual) {
      slugField.value = nameField.value.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
    }
  });
  slugField.addEventListener('input', function() { slugField.dataset.manual = '1'; });
}

// filter properties
function filterProps() {
  const q = (document.getElementById('searchProp').value || '').toLowerCase();
  const l = document.getElementById('filterListing').value;
  document.querySelectorAll('#propGrid .prop-card').forEach(card => {
    const nameMatch = !q || card.dataset.name.includes(q);
    const listMatch = !l || card.dataset.listing === l;
    card.style.display = nameMatch && listMatch ? '' : 'none';
  });
}

// open add panel if URL hash says so
if (location.hash === '#add') showPanel('add');
if (location.search.includes('tab=enquiries')) showPanel('enquiries');
if (location.search.includes('tab=agent-listings')) showPanel('agent-listings');
if (location.search.includes('tab=agents')) showPanel('agents');
if (location.search.includes('tab=payments')) showPanel('payments');
if (location.search.includes('tab=webhooks')) showPanel('webhooks');

// filter enquiries
function filterEnquiries() {
  const q = (document.getElementById('searchEnq').value || '').toLowerCase();
  const f = document.getElementById('filterEnqStatus').value;
  document.querySelectorAll('#enqGrid .enq-card').forEach(card => {
    const textContent = (card.dataset.name + ' ' + card.dataset.details).toLowerCase();
    const textMatch = !q || textContent.includes(q);
    const statusMatch = !f || (f === 'unread' && card.dataset.read === '0') || (f === 'read' && card.dataset.read === '1');
    card.style.display = textMatch && statusMatch ? '' : 'none';
  });
}

// ── gallery multi-preview ──
function previewGallery(input, containerId) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  Array.from(input.files).forEach(function(file) {
    const img = document.createElement('img');
    img.src = URL.createObjectURL(file);
    img.style.cssText = 'width:80px;height:54px;object-fit:cover;border-radius:10px;border:1px solid #e0ddd6';
    container.appendChild(img);
  });
}

// ── tag-input (amenities + pills) ──
(function() {
  var style = document.createElement('style');
  style.textContent = [
    '.tag-input{display:flex;flex-wrap:wrap;gap:6px;padding:8px 12px;border:1px solid transparent;border-radius:12px;min-height:44px;cursor:text;background:var(--surface2)}',
    '.tag-input:focus-within{background:#fff;border-color:#0F0F12;box-shadow:0 0 0 3px rgba(15,15,18,0.06)}',
    '.tag-chip{display:inline-flex;align-items:center;gap:6px;background:#0F0F12;color:#fff;border-radius:999px;padding:4px 12px;font-size:12px;font-weight:700}',
    '.tag-chip button{background:none;border:0;cursor:pointer;color:#8E8E93;font-size:14px;line-height:1;padding:0 2px}',
    '.tag-chip button:hover{color:#fff}',
    '.tag-typeahead{border:0;outline:0;flex:1;min-width:120px;font:inherit;font-size:13.5px;background:none;padding:2px 4px}',
    '.gallery-prev{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}',
  ].join('');
  document.head.appendChild(style);

  function initTagInput(containerEl, hiddenInputId) {
    if (!containerEl) return;
    var hidden = document.getElementById(hiddenInputId);
    var chips = [];

    var input = document.createElement('input');
    input.className = 'tag-typeahead';
    input.placeholder = 'Type and press Enter…';
    containerEl.appendChild(input);

    function sync() {
      if (hidden) hidden.value = chips.join('|');
    }
    function addChip(val) {
      val = val.trim();
      if (!val || chips.indexOf(val) !== -1) return;
      chips.push(val);
      var chip = document.createElement('span');
      chip.className = 'tag-chip';
      chip.textContent = val;
      var del = document.createElement('button');
      del.type = 'button';
      del.textContent = '×';
      del.addEventListener('click', function() {
        chips.splice(chips.indexOf(val), 1);
        chip.remove();
        sync();
      });
      chip.appendChild(del);
      containerEl.insertBefore(chip, input);
      sync();
    }

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        addChip(input.value.replace(/,/g,''));
        input.value = '';
      } else if (e.key === 'Backspace' && !input.value && chips.length) {
        var last = chips[chips.length - 1];
        chips.pop();
        containerEl.querySelectorAll('.tag-chip')[containerEl.querySelectorAll('.tag-chip').length - 1].remove();
        sync();
      }
    });
    input.addEventListener('blur', function() {
      if (input.value.trim()) { addChip(input.value); input.value = ''; }
    });
    containerEl.addEventListener('click', function() { input.focus(); });

    if (hidden && hidden.value) {
      hidden.value.split('|').forEach(function(v) { addChip(v); });
    }
  }

  initTagInput(document.getElementById('amen-tags-add'), 'amenities-add');
  initTagInput(document.getElementById('pills-tags-add'), 'setting_pills-add');
})();
</script>
</body>
</html>
