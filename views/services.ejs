<!doctype html>
<html lang="en">
<head>
<%- include('partials/head') %>
<link rel="stylesheet" href="/assets/market.css?v=3">
<style>
  .page-top{padding:120px 0 30px}
  .page-top h1{font-family:var(--f-display);font-weight:500;font-size:clamp(34px,5.6vw,72px);line-height:1;letter-spacing:-.015em;margin-top:14px;max-width:16ch}
  .page-top h1 .it{font-style:italic;color:var(--accent)}
  .page-top p{margin-top:16px;color:var(--ink-3);font-size:16px;max-width:54ch;line-height:1.6}
  .srow{display:grid;gap:clamp(24px,4vw,64px);align-items:start;padding:clamp(44px,6vw,82px) 0;border-top:1px solid var(--line)}
  @media(min-width:880px){.srow{grid-template-columns:.85fr 1.15fr}}
  .srow .si .n{font-family:var(--f-mono);font-size:12px;letter-spacing:.16em;color:var(--gold-deep)}
  .srow .si .ic{width:42px;height:42px;color:var(--accent);margin:16px 0}
  .srow .si h2{font-family:var(--f-display);font-weight:500;font-size:clamp(28px,3.6vw,44px);line-height:1.04;letter-spacing:-.01em}
  .srow .sb p{font-size:clamp(15px,1.5vw,17px);line-height:1.7;color:var(--ink-2);max-width:56ch;margin-bottom:22px}
  .offer{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:10px 26px;margin-bottom:26px}
  @media(max-width:560px){.offer{grid-template-columns:1fr}}
  .offer li{display:flex;gap:10px;align-items:baseline;font-size:14.5px;color:var(--ink-2);padding:9px 0;border-bottom:1px solid var(--line-soft)}
  .offer li .d{width:5px;height:5px;border-radius:50%;background:var(--gold-deep);flex:none;transform:translateY(-2px)}
  .srow .acts{display:flex;gap:12px;flex-wrap:wrap}
</style>
</head>
<body data-screen-label="Services">

<%- include('partials/nav') %>

<header class="page-top wrap">
  <div class="crumb"><a href="/">Home</a><span class="sep">/</span><span>Services</span></div>
  <h1>Everything property, under <span class="it">one roof.</span></h1>
  <p>Most people juggle a broker, a banker, a lawyer and a contractor. We put them on one team, so the right hand always knows what the left is doing.</p>
  <div class="svc-grid" style="margin-top:36px">
    <% services.forEach(function(s) { %>
    <a class="svc-tile" href="#<%= s.id %>">
      <span class="n"><%= s.n %></span>
      <span class="ic"><%- s.icon_svg %></span>
      <h3><%= s.title %></h3>
      <p><%= s.desc %></p>
    </a>
    <% }) %>
  </div>
</header>

<main class="wrap">
  <% serviceDetails.forEach(function(s) { %>
  <section class="srow" id="<%= s.id %>">
    <div class="si">
      <span class="n"><%= s.n %></span>
      <div class="ic"><%- s.icon_svg %></div>
      <h2><%= s.title %></h2>
    </div>
    <div class="sb">
      <p><%= s.long_desc %></p>
      <ul class="offer">
        <% s.offers.forEach(function(o) { %>
        <li><span class="d"></span><%= o %></li>
        <% }) %>
      </ul>
      <div class="acts">
        <a class="btn btn-dark" href="/contact?service=<%= s.id %>"><span>Enquire about this service</span><span class="arr">→</span></a>
      </div>
    </div>
  </section>
  <% }) %>
</main>

<section class="lead">
  <div class="wrap"><div class="lead-grid" style="grid-template-columns:1fr;text-align:center;place-items:center">
    <div>
      <span class="kicker" style="color:var(--gold)">Not sure where to start?</span>
      <h2 style="margin-top:14px">Tell us the goal. <span class="it">We'll map the path.</span></h2>
      <p class="lead-sub" style="margin-inline:auto">One conversation and we'll tell you which services you actually need, and which you don't.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:24px">
        <a class="btn btn-dark" href="/contact"><span>Talk to a specialist</span><span class="arr">→</span></a>
        <a class="btn btn-ghost" href="https://wa.me/919036001234?text=Hi%20RichManAssets%2C%20I%27d%20like%20to%20discuss%20your%20services." target="_blank" rel="noopener"><span>WhatsApp us</span></a>
      </div>
    </div>
  </div></div>
</section>

<%- include('partials/footer') %>
<script>
  const nav = document.getElementById('nav');
  nav.classList.add('solid');
  const io = new IntersectionObserver((es) => es.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  }), { threshold: .08 });
  document.querySelectorAll('.svc-tile, .srow').forEach(el => { el.classList.add('reveal'); io.observe(el); });
</script>
</body>
</html>
